# Global satır sonu ayarı (Otomatik algıla ve LF olarak sakla)
* text=auto eol=lf

# Özel dosya tipleri için kesin kurallar
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf

# Binary dosyalar (Değiştirilmemeli)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary